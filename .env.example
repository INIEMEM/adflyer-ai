AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TEXT_MODEL=gpt-4o

# ── Image Generation ──────────────────────────────────────────────────────────
# Set IMAGE_PROVIDER to: huggingface | openai | pollinations | gemini
IMAGE_PROVIDER=huggingface

# Hugging Face (free tier) — recommended for image generation
HF_TOKEN=your_huggingface_token_here
HF_MODEL=black-forest-labs/FLUX.1-dev

# OpenAI image fallback (optional)
OPENAI_IMAGE_MODEL=dall-e-3

# Pollinations (free, no key needed)
POLLINATIONS_IMAGE_URL=https://image.pollinations.ai

# Google Gemini (optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

IMAGE_GEN_API_KEY=
CLIENT_URL=http://localhost:5173
